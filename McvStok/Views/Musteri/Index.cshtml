@using McvStok.Models.Entity
@model List<TBLMUSTERILER>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@using (Html.BeginForm("Index","Musteri",FormMethod.Get))
            {
                <p>
                 <b>Aranacak Müşteri Adı: </b>  @Html.TextBox("p")
                    <input type="submit"  value="Ara" />
                </p>
            }
<table class="table table-bordered">
    <tr>
        <th>MÜŞTERİ ID</th>
        <th>MÜŞTERİ ADI</th>
        <th>MÜŞTERİ SOYADI</th>
        <th>SİL </th>
        <th>GÜNCELLE</th>
        <th>ALERT</th>
    </tr>
    <tbody>
        @foreach (var ktgr in Model)
        {
            <tr>
                <td>@ktgr.MUSTERIID</td>
                <td>@ktgr.MUSTERIAD</td>
                <td>@ktgr.MUSTERISOYAD</td>

                <td>
                    <a href="/Musteri/SIL/@ktgr.MUSTERIID" class="btn btn-danger">SİL </a>
                </td>
                <td>
                    <a href="/Musteri/MusteriGetir/@ktgr.MUSTERIID" class="btn btn-success">GÜNCELLE </a>
                </td>
                <td>@Html.ActionLink("SİL BUTONU", "SIL", new { id = ktgr.MUSTERIID }, new { @class = "btn btn-warning", onclick = "return confirm('Emin misin?')" }) </td>
            </tr>
            }
    </tbody>
</table>

<a href="/Musteri/YeniMusterı/" class="btn btn-primary">YENİ MÜŞTERİ EKLE</a>